{
  "name": "pufflabs-desktop",
  "productName": "PuffLabs",
  "version": "0.2.3",
  "description": "PuffLabs Communications — cross-platform desktop app (macOS + Windows; thin shell around the live site)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac dmg",
    "dist:mac": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.106.2"
  },
  "build": {
    "appId": "work.pufflabs.desktop",
    "productName": "PuffLabs",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business",
      "icon": "icon.png",
      "identity": null
    },
    "dmg": {
      "artifactName": "PuffLabs.dmg"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "artifactName": "PuffLabs-Setup.exe",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PuffLabs"
    },
    "protocols": [
      {
        "name": "PuffLabs",
        "schemes": [
          "pufflabs"
        ]
      }
    ]
  }
}
